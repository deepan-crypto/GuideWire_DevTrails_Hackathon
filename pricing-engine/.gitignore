# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl

# ──────────────────────────────────────────────
# Virtual Environment
# ──────────────────────────────────────────────
venv/
.venv/
env/
.env

# ──────────────────────────────────────────────
# IDE / Editor
# ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath

# ──────────────────────────────────────────────
# ML Artifacts (large binaries — don't commit)
# ──────────────────────────────────────────────
models/artifacts/*.joblib
models/artifacts/*.pkl
models/artifacts/*.json
!models/artifacts/.gitkeep

# ──────────────────────────────────────────────
# Generated Data (large files — don't commit)
# ──────────────────────────────────────────────
data/synthetic/*.parquet
data/synthetic/*.csv
!data/synthetic/.gitkeep

# ──────────────────────────────────────────────
# Jupyter Notebooks
# ──────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ──────────────────────────────────────────────
# OS
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ──────────────────────────────────────────────
# Logs & Temp
# ──────────────────────────────────────────────
*.log
logs/
tmp/
temp/

# ──────────────────────────────────────────────
# Misc
# ──────────────────────────────────────────────
.qodo/